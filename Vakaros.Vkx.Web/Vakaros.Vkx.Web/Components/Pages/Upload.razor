@page "/upload"
@using Vakaros.Vkx.Shared.Dtos.Sessions
@inject VakarosApiClient Api
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Upload VKX File</PageTitle>

<h1>Upload VKX File</h1>

<p>Select a <code>.vkx</code> file to upload and create a new session.</p>

<div class="upload-area">
    <InputFile OnChange="OnFileSelected" accept=".vkx" disabled="@_uploading" />

    @if (_uploading)
    {
        <p><em>Uploading…</em></p>
    }

    @if (_error is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <strong>Upload failed</strong>
                <p>@_error</p>
            </div>
        </div>
    }
</div>

@code {
    private bool _uploading;
    private string? _error;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _uploading = true;

        try
        {
            var file = e.File;
            const long maxSize = 100 * 1024 * 1024; // 100 MB
            await using var stream = file.OpenReadStream(maxSize);

            var session = await Api.UploadSessionAsync(stream, file.Name);

            if (session is not null)
            {
                Nav.NavigateTo($"/sessions/{session.Id}");
                return;
            }

            _error = "The server did not return a session. Please try again.";
        }
        catch (HttpRequestException ex)
        {
            _error = $"Could not reach the API: {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _uploading = false;
        }
    }
}
