@page "/sessions/{Id:int}"
@using Vakaros.Vkx.Shared.Dtos
@using Vakaros.Vkx.Shared.Dtos.Courses
@using Vakaros.Vkx.Shared.Dtos.Races
@inject VakarosApiClient Api
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Session @Id</PageTitle>

<nav>
    <a href="/sessions">← Sessions</a>
</nav>

@if (_loading)
{
    <p><em>Loading session…</em></p>
}
else if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load session</strong>
            <p>@_error</p>
        </div>
    </div>
}
else if (_session is null)
{
    <p>Session not found.</p>
}
else
{
    <h1>@_session.FileName</h1>

    <div class="session-meta">
        <dl>
            <dt>Boat</dt>
            <dd>@(_session.BoatName ?? "—")</dd>

            <dt>Course</dt>
            <dd>@(_session.CourseName ?? "—")</dd>

            <dt>Started</dt>
            <dd>@_session.StartedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</dd>

            <dt>Ended</dt>
            <dd>@_session.EndedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</dd>

            <dt>Telemetry Rate</dt>
            <dd>@_session.TelemetryRateHz Hz</dd>

            <dt>Format Version</dt>
            <dd>@_session.FormatVersion</dd>

            @if (_session.Notes is not null)
            {
                <dt>Notes</dt>
                <dd>@_session.Notes</dd>
            }
        </dl>
    </div>

    <h2>Races</h2>

    @if (_session.Races.Count == 0)
    {
        <p>No races detected in this session.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Race #</th>
                    <th>Started</th>
                    <th>Ended</th>
                    <th>Duration</th>
                    <th>Course</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var race in _session.Races)
                {
                    @if (_editingRaceNumber == race.RaceNumber)
                    {
                        <tr>
                            <td>@race.RaceNumber</td>
                            <td>@race.StartedAt.LocalDateTime.ToString("HH:mm:ss")</td>
                            <td>@race.EndedAt.LocalDateTime.ToString("HH:mm:ss")</td>
                            <td>@FormatDuration(race.DurationSeconds)</td>
                            <td>
                                <select @bind="_raceFormCourseId">
                                    <option value="0">— none —</option>
                                    @if (_courses is not null)
                                    {
                                        @foreach (var c in _courses)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn btn-sm" @onclick="SaveRaceEdit">Save</button>
                                <button class="btn btn-sm" @onclick="CancelRaceEdit">Cancel</button>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@race.RaceNumber</td>
                            <td>@race.StartedAt.LocalDateTime.ToString("HH:mm:ss")</td>
                            <td>@race.EndedAt.LocalDateTime.ToString("HH:mm:ss")</td>
                            <td>@FormatDuration(race.DurationSeconds)</td>
                            <td>@(race.CourseName ?? "—")</td>
                            <td>
                                <button class="btn btn-sm" @onclick="() => StartRaceEdit(race)" disabled="@(_editingRaceNumber is not null)">Edit Course</button>
                                <a href="/sessions/@Id/races/@race.RaceNumber" class="btn-view-race">
                                    View Race →
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (_raceActionError is not null)
        {
            <div class="api-error" role="alert">
                <span class="api-error-icon">⚠️</span>
                <div class="api-error-body">
                    <p>@_raceActionError</p>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private SessionDetailDto? _session;
    private List<CourseSummaryDto>? _courses;
    private bool _loading = true;
    private string? _error;

    // Race edit state
    private int? _editingRaceNumber;
    private int _raceFormCourseId;
    private string? _raceActionError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var sessionTask = Api.GetSessionAsync(Id);
            var coursesTask = Api.GetCoursesAsync();
            await Task.WhenAll(sessionTask, coursesTask);
            _session = sessionTask.Result;
            _courses = coursesTask.Result;
        }
        catch (HttpRequestException)
        {
            _error = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartRaceEdit(RaceDto race)
    {
        _raceActionError = null;
        _editingRaceNumber = race.RaceNumber;
        _raceFormCourseId = race.CourseId ?? 0;
    }

    private void CancelRaceEdit()
    {
        _editingRaceNumber = null;
        _raceActionError = null;
    }

    private async Task SaveRaceEdit()
    {
        _raceActionError = null;
        if (_editingRaceNumber is null || _session is null) return;

        try
        {
            var updated = await Api.PatchRaceAsync(Id, _editingRaceNumber.Value, new PatchRaceRequest(_raceFormCourseId));
            if (updated is not null)
            {
                var idx = _session.Races.FindIndex(r => r.RaceNumber == _editingRaceNumber.Value);
                if (idx >= 0)
                {
                    var r = _session.Races[idx];
                    var courseName = _courses?.FirstOrDefault(c => c.Id == updated.CourseId)?.Name;
                    _session.Races[idx] = r with { CourseId = updated.CourseId, CourseName = courseName };
                }
            }
            _editingRaceNumber = null;
        }
        catch (HttpRequestException)
        {
            _raceActionError = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _raceActionError = $"An unexpected error occurred: {ex.Message}";
        }
    }

    private static string FormatDuration(double totalSeconds)
    {
        var span = TimeSpan.FromSeconds(totalSeconds);
        return span.TotalHours >= 1
            ? $"{(int)span.TotalHours}h {span.Minutes:D2}m {span.Seconds:D2}s"
            : $"{span.Minutes}m {span.Seconds:D2}s";
    }
}
