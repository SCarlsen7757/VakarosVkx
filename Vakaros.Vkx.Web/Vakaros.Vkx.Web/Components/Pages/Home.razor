@page "/"
@using Vakaros.Vkx.Shared.Dtos.Stats
@inject VakarosApiClient Api
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

@if (_loading)
{
    <div class="stats-grid">
        @for (int i = 0; i < 6; i++)
        {
            <div class="skeleton" style="height:110px;"></div>
        }
    </div>
}
else if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load statistics</strong>
            <p>@_error</p>
        </div>
    </div>
}
else if (_stats is not null)
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-card-label">Boats</div>
            <div class="stat-card-value">@_stats.TotalBoats</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Sessions</div>
            <div class="stat-card-value">@_stats.TotalSessions</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Races</div>
            <div class="stat-card-value">@_stats.TotalRaces</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Total Distance</div>
            <div class="stat-card-value">
                @((_stats.TotalSailedDistanceMeters / 1852.0).ToString("N1"))<span class="stat-card-unit">nm</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Top Speed</div>
            <div class="stat-card-value">
                @((_stats.TopSpeedOverGround * 1.94384).ToString("N1"))<span class="stat-card-unit">kn</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Race Time</div>
            <div class="stat-card-value">
                @(TimeSpan.FromSeconds(_stats.TotalRaceDurationSeconds).TotalHours.ToString("N0"))<span class="stat-card-unit">hrs</span>
            </div>
        </div>
    </div>

    @if (_stats.EarliestSessionAt is not null && _stats.LatestSessionAt is not null)
    {
        <p style="font-size:0.85rem;color:#64748b;">
            Data from @_stats.EarliestSessionAt.Value.ToString("MMM d, yyyy") to @_stats.LatestSessionAt.Value.ToString("MMM d, yyyy")
        </p>
    }
}
else
{
    <p>No data yet. <a href="/upload">Upload a VKX file</a> to get started.</p>
}

@code {
    private GlobalStatsDto? _stats;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await Api.GetGlobalStatsAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
