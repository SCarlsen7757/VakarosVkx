                </NavLink>
            </li>
            <li>
                <NavLink href="/sessions" Match="NavLinkMatch.Prefix">
                    Sessions
                </NavLink>
            </li>
            <li>
                <NavLink href="/boats" Match="NavLinkMatch.Prefix">
                    Boats
                </NavLink>
            </li>
            <li>
                <NavLink href="/boat-classes" Match="NavLinkMatch.Prefix">
                    Boat Classes
                </NavLink>
            </li>
            <li>
                <NavLink href="/marks" Match="NavLinkMatch.Prefix">
                    Marks
                </NavLink>
            </li>
            <li>
                <NavLink href="/courses" Match="NavLinkMatch.Prefix">
                    Courses
                </NavLink>
            </li>
            <li>
                <NavLink href="/settings" Match="NavLinkMatch.All">
