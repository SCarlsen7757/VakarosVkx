# Dev-only image — used by docker-compose.override.yml.
# Source code is mounted as a volume at runtime, so JS/TS changes hot-reload
# instantly without rebuilding this image.
# Rebuild this image only when package.json dependencies change.
FROM node:25-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci
EXPOSE 3000
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
CMD ["npm", "run", "dev"]
