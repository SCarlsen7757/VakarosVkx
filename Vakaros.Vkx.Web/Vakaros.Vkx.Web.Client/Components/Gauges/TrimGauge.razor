@namespace Vakaros.Vkx.Web.Client.Components.Gauges

<div class="gauge-card angle-gauge">
    <div class="gauge-header">
        <span class="gauge-label">@Label</span>
        <button class="gauge-toggle" @onclick="ToggleMode" title="Toggle view">
            @(ShowAngle ? "123" : "∠")
        </button>
    </div>

    @if (!Value.HasValue)
    {
        <div class="gauge-value">
            <span class="gauge-number gauge-no-data">—</span>
        </div>
    }
    else if (!ShowAngle)
    {
        <div class="angle-visual inclinometer-visual">
            <svg viewBox="0 35 140 85" width="100%">
                <g transform="translate(70, 0)">
                    <!-- Minimal smooth track -->
                    <path d="M -42.42 42.42 A 60 60 0 0 0 42.42 42.42" fill="none" stroke="#e9ecef" stroke-width="6" stroke-linecap="round" />

                    <!-- Ticks and Labels -->
                    @for (double i = -5; i <= 5; i += 0.5)
                    {
                        var isMajor = Math.Abs(i % 1) < 0.01;
                        var rotation = i * 9.0;
                        if (isMajor)
                        {
                            <line x1="0" y1="66" x2="0" y2="72" stroke="currentColor" opacity="0.5" stroke-width="1.5" transform="rotate(@(-rotation), 0, 0)" />
                            @((MarkupString)$"<text x='0' y='86' text-anchor='middle' fill='currentColor' opacity='0.7' font-size='10' font-family='sans-serif' transform='rotate({-rotation}, 0, 0)'>{Math.Abs(i)}</text>")
                        }
                        else
                        {
                            <line x1="0" y1="66" x2="0" y2="69" stroke="currentColor" opacity="0.3" stroke-width="1" transform="rotate(@(-rotation), 0, 0)" />
                        }
                    }

                    <!-- Center indicator -->
                    <line x1="0" y1="62" x2="0" y2="72" stroke="currentColor" stroke-width="2" opacity="0.8" />

                    <!-- Simple Indicator Ball -->
                    <g style="transform-origin: 0px 0px; transform: rotate(@(-ClampedAngle * 9.0)deg); transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
                        <circle cx="0" cy="60" r="4.5" fill="#e63946" />
                    </g>
                </g>
                <!-- Central digital readout -->
                @((MarkupString)$"<text x='70' y='110' text-anchor='middle' fill='currentColor' font-size='15' font-weight='bold'>{Value.Value.ToString("F1")}°</text>")
            </svg>
        </div>
    }
    else
    {
        <div class="angle-visual">
            <svg viewBox="0 25 120 95" width="100%">
                <!-- Water line (fixed horizon) -->
                <line x1="10" y1="70" x2="110" y2="70" stroke="#457b9d" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.5" />

                <!-- Boat side-profile (rotated by trim angle) -->
                <g style="transform-origin: 60px 65px; transform: rotate(@(ClampedAngle)deg); transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
                    <!-- Hull side profile -->
                    <path d="M15,65 Q20,80 60,82 Q100,80 105,65 Q100,62 60,60 Q20,62 15,65 Z" fill="#264653" />
                    <!-- Deck line -->
                    <line x1="20" y1="63" x2="100" y2="63" stroke="#2a9d8f" stroke-width="1.5" />
                    <!-- Bow marker -->
                    <circle cx="100" cy="63" r="2.5" fill="#e63946" />
                    <!-- Mast -->
                    <line x1="45" y1="63" x2="45" y2="30" stroke="#e9c46a" stroke-width="2" />
                </g>

                <!-- Angle readout -->
                @((MarkupString)$"<text x='60' y='115' text-anchor='middle' fill='currentColor' font-size='15' font-weight='bold'>{Value.Value.ToString("F1")}°</text>")
            </svg>
        </div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "Trim";
    [Parameter] public double? Value { get; set; }

    private bool ShowAngle { get; set; } = true;

    private double ClampedAngle => Value.HasValue ? Math.Clamp(Value.Value, -5, 5) : 0;

    private void ToggleMode() => ShowAngle = !ShowAngle;
}
