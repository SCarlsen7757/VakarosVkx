@namespace Vakaros.Vkx.Web.Client.Components.Gauges

<div class="gauge-card">
    <div class="gauge-label">@Label</div>
    <div class="gauge-value">
        @if (Value.HasValue)
        {
            <span class="gauge-number">@Value.Value.ToString("F1")</span>
            <span class="gauge-unit">@Unit</span>
        }
        else
        {
            <span class="gauge-number gauge-no-data">—</span>
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "Speed";
    [Parameter] public string Unit { get; set; } = "kn";
    [Parameter] public double? Value { get; set; }
}
