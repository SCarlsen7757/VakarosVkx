@namespace Vakaros.Vkx.Web.Client.Components.Shared
@using Vakaros.Vkx.Shared.Dtos.Telemetry
@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="@_containerId" class="time-window-slicer">
    <div class="tw-labels">
        <span class="tw-label-start">--:--:--</span>
        <span class="tw-label-duration">--</span>
        <span class="tw-label-end">--:--:--</span>
    </div>
    <div class="tw-track">
        <input type="range" class="tw-slider-start" min="0" max="0" value="0" />
        <input type="range" class="tw-slider-end" min="0" max="0" value="0" />
    </div>
</div>

@code {
    [Parameter] public List<PositionDto>? Positions { get; set; }
    [Parameter] public EventCallback<(DateTimeOffset Start, DateTimeOffset End)> OnWindowChanged { get; set; }

    private readonly string _containerId = $"tw-{Guid.NewGuid():N}";
    private DotNetObjectReference<TimeWindowSlicer>? _dotNetRef;
    private bool _jsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Positions is { Count: > 0 })
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("timeWindowInterop.init",
                _containerId, Positions, _dotNetRef, nameof(OnWindowChangedFromJs));
            _jsInitialized = true;
        }
    }

    /// <summary>
    /// Sets the window range programmatically from an external source.
    /// </summary>
    public async Task SetWindowAsync(DateTimeOffset start, DateTimeOffset end)
    {
        if (_jsInitialized)
        {
            await JS.InvokeVoidAsync("timeWindowInterop.setWindow",
                start.ToString("O"), end.ToString("O"));
        }
    }

    [JSInvokable]
    public async Task OnWindowChangedFromJs(int startIdx, int endIdx)
    {
        if (Positions is null || Positions.Count == 0) return;

        startIdx = Math.Clamp(startIdx, 0, Positions.Count - 1);
        endIdx = Math.Clamp(endIdx, 0, Positions.Count - 1);

        var start = Positions[startIdx].Time;
        var end = Positions[endIdx].Time;
        await OnWindowChanged.InvokeAsync((start, end));
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("timeWindowInterop.dispose");
            }
            catch
            {
                // Ignore JS interop errors during disposal
            }
        }
        _dotNetRef?.Dispose();
    }
}
