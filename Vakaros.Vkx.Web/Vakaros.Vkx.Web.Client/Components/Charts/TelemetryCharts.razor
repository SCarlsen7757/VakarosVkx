@namespace Vakaros.Vkx.Web.Client.Components.Charts
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="telemetry-charts">
    @if (_initError is not null)
    {
        <p style="color:red;font-size:0.8rem;padding:0.5rem">Chart error: @_initError</p>
    }
    @if (_chartIds is not null)
    {
        @foreach (var id in _chartIds)
        {
            <div id="@id" style="width:100%;height:180px;"></div>
        }
    }
</div>

@code {
    [Parameter] public List<ChartPanelConfig>? Charts { get; set; }
    [Parameter] public EventCallback<string> OnCursorMoved { get; set; }

    private DotNetObjectReference<TelemetryCharts>? _dotNetRef;
    private bool _chartsInitialized;

    private List<string>? _chartIds;
    private List<ChartPanelConfig>? _prevCharts;
    private string? _initError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (!_chartsInitialized && _chartIds is { Count: > 0 })
        {
            try
            {
                await InitializeChartsAsync();
                _chartsInitialized = true;
                await PushDataToChartsAsync();
                _prevCharts = Charts;

                // Tell timeWindowInterop which chart containers exist so it can
                // push resampled data directly in JS without a WASM round-trip.
                await JS.InvokeVoidAsync("timeWindowInterop.setChartIds", _chartIds);
            }
            catch (JSException ex)
            {
                _initError = ex.Message;
                Console.Error.WriteLine($"[TelemetryCharts] JS initialization failed: {ex.Message}");
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_chartIds is null && Charts is { Count: > 0 })
        {
            _chartIds = Charts.Select(_ => $"chart-{Guid.NewGuid():N}").ToList();
            return;
        }

        if (_chartsInitialized && HasDataChanged())
        {
            await PushDataToChartsAsync();
            _prevCharts = Charts;
        }
    }

    private bool HasDataChanged()
    {
        if (!ReferenceEquals(Charts, _prevCharts)) return true;
        if (Charts is null || _prevCharts is null) return false;
        if (Charts.Count != _prevCharts.Count) return true;
        for (int i = 0; i < Charts.Count; i++)
        {
            if (!ReferenceEquals(Charts[i].Data, _prevCharts[i].Data)) return true;
        }
        return false;
    }

    private async Task InitializeChartsAsync()
    {
        if (Charts is null || _chartIds is null) return;

        var configs = Charts.Select((panel, i) => new
        {
            containerId = _chartIds[i],
            yAxisLabel = panel.YAxisLabel,
            series = panel.Series.Select(s => new { name = s.Name, valueField = s.ValueField, color = s.Color }).ToArray()
        }).ToArray();

        await JS.InvokeVoidAsync("amchartsInterop.initCharts", configs, _dotNetRef, nameof(OnChartCursorMove));
    }

    private async Task PushDataToChartsAsync()
    {
        if (Charts is null || _chartIds is null) return;

        for (int i = 0; i < Charts.Count; i++)
        {
            var panel = Charts[i];
            if (panel.Data is not { Count: > 0 }) continue;
            try
            {
                await JS.InvokeVoidAsync("amchartsInterop.setChartData", _chartIds[i], panel.Data);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[TelemetryCharts] setChartData failed for panel {i}: {ex.Message}");
            }
        }
    }

    public async Task SyncCursorAsync(string isoTimestamp)
    {
        if (_chartsInitialized)
        {
            await JS.InvokeVoidAsync("amchartsInterop.syncCursor", isoTimestamp);
        }
    }

    public async Task SetTimeWindowAsync(DateTimeOffset start, DateTimeOffset end)
    {
        if (_chartsInitialized)
        {
            await JS.InvokeVoidAsync("amchartsInterop.setTimeWindow",
                start.ToString("O"), end.ToString("O"));
        }
    }

    [JSInvokable]
    public async Task OnChartCursorMove(string isoTimestamp)
    {
        await OnCursorMoved.InvokeAsync(isoTimestamp);
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("amchartsInterop.disposeCharts");
            }
            catch (JSException)
            {
                // Ignore JS exceptions during disposal, as the charts may already be cleaned up
            }
        }
        _dotNetRef?.Dispose();
    }
}

