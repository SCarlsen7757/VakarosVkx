@namespace Vakaros.Vkx.Web.Client.Components.Charts
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="telemetry-charts">
    <div id="@SpeedChartId" style="width:100%;height:180px;"></div>
    <div id="@HeelChartId" style="width:100%;height:180px;"></div>
    <div id="@TrimChartId" style="width:100%;height:180px;"></div>
    <div id="@HeadingChartId" style="width:100%;height:180px;"></div>
</div>

@code {
    [Parameter] public List<ChartDataPoint>? SpeedData { get; set; }
    [Parameter] public List<ChartDataPoint>? HeelData { get; set; }
    [Parameter] public List<ChartDataPoint>? TrimData { get; set; }
    [Parameter] public List<ChartDataPoint>? HeadingData { get; set; }
    [Parameter] public EventCallback<string> OnCursorMoved { get; set; }

    private string SpeedChartId = $"chart-speed-{Guid.NewGuid():N}";
    private string HeelChartId = $"chart-heel-{Guid.NewGuid():N}";
    private string TrimChartId = $"chart-trim-{Guid.NewGuid():N}";
    private string HeadingChartId = $"chart-heading-{Guid.NewGuid():N}";

    private DotNetObjectReference<TelemetryCharts>? _dotNetRef;
    private bool _chartsInitialized;

    // Change-detection: only re-push data when the list references actually change.
    private List<ChartDataPoint>? _prevSpeedData;
    private List<ChartDataPoint>? _prevHeelData;
    private List<ChartDataPoint>? _prevTrimData;
    private List<ChartDataPoint>? _prevHeadingData;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await InitializeChartsAsync();
            _chartsInitialized = true;
            await PushDataToChartsAsync();
            SnapshotDataReferences();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_chartsInitialized && HasDataChanged())
        {
            await PushDataToChartsAsync();
            SnapshotDataReferences();
        }
    }

    private bool HasDataChanged() =>
        !ReferenceEquals(SpeedData, _prevSpeedData) ||
        !ReferenceEquals(HeelData, _prevHeelData) ||
        !ReferenceEquals(TrimData, _prevTrimData) ||
        !ReferenceEquals(HeadingData, _prevHeadingData);

    private void SnapshotDataReferences()
    {
        _prevSpeedData = SpeedData;
        _prevHeelData = HeelData;
        _prevTrimData = TrimData;
        _prevHeadingData = HeadingData;
    }

    private async Task InitializeChartsAsync()
    {
        var configs = new object[]
        {
            new {
                containerId = SpeedChartId,
                yAxisLabel = "Speed (kn)",
                series = new object[] {
                    new { name = "SOG", valueField = "sog", color = "#457b9d" },
                    new { name = "STW", valueField = "stw", color = "#2a9d8f" }
                }
            },
            new {
                containerId = HeelChartId,
                yAxisLabel = "Heel (°)",
                series = new object[] {
                    new { name = "Heel", valueField = "heel", color = "#f4a261" }
                }
            },
            new {
                containerId = TrimChartId,
                yAxisLabel = "Trim (°)",
                series = new object[] {
                    new { name = "Trim", valueField = "trim", color = "#264653" }
                }
            },
            new {
                containerId = HeadingChartId,
                yAxisLabel = "Heading (°)",
                series = new object[] {
                    new { name = "COG", valueField = "cog", color = "#6a4c93" },
                    new { name = "True Hdg", valueField = "trueHeading", color = "#1982c4" }
                }
            }
        };

        await JS.InvokeVoidAsync("amchartsInterop.initCharts", configs, _dotNetRef, nameof(OnChartCursorMove));
    }

    private async Task PushDataToChartsAsync()
    {
        if (SpeedData is { Count: > 0 })
            await JS.InvokeVoidAsync("amchartsInterop.setChartData", SpeedChartId, SpeedData);
        if (HeelData is { Count: > 0 })
            await JS.InvokeVoidAsync("amchartsInterop.setChartData", HeelChartId, HeelData);
        if (TrimData is { Count: > 0 })
            await JS.InvokeVoidAsync("amchartsInterop.setChartData", TrimChartId, TrimData);
        if (HeadingData is { Count: > 0 })
            await JS.InvokeVoidAsync("amchartsInterop.setChartData", HeadingChartId, HeadingData);
    }

    public async Task SyncCursorAsync(string isoTimestamp)
    {
        if (_chartsInitialized)
        {
            await JS.InvokeVoidAsync("amchartsInterop.syncCursor", isoTimestamp);
        }
    }

    [JSInvokable]
    public async Task OnChartCursorMove(string isoTimestamp)
    {
        await OnCursorMoved.InvokeAsync(isoTimestamp);
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("amchartsInterop.disposeCharts");
            }
            catch (JSException)
            {
                // Ignore JS exceptions during disposal, as the charts may already be cleaned up
            }
        }
        _dotNetRef?.Dispose();
    }

    /// <summary>
    /// Generic chart data point with all possible fields.
    /// Each chart panel reads only the fields it needs.
    /// </summary>
    public class ChartDataPoint
    {
        public string Time { get; set; } = "";
        public double? Sog { get; set; }
        public double? Stw { get; set; }
        public double? Vmg { get; set; }
        public double? Heel { get; set; }
        public double? Trim { get; set; }
        public double? Cog { get; set; }
        public double? TrueHeading { get; set; }
    }
}
