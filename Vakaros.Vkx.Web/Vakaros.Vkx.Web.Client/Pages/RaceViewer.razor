@page "/sessions/{SessionId:int}/races/{RaceNumber:int}"
@using Vakaros.Vkx.Shared.Dtos
@using Vakaros.Vkx.Shared.Dtos.Courses
@using Vakaros.Vkx.Shared.Dtos.Races
@using Vakaros.Vkx.Shared.Dtos.Telemetry
@using Vakaros.Vkx.Web.Client.Components.Charts
@using Vakaros.Vkx.Web.Client.Components.Gauges
@using Vakaros.Vkx.Web.Client.Components.Map
@using Vakaros.Vkx.Web.Client.Components.Shared
@using Vakaros.Vkx.Web.Client.Services
@inject VakarosApiClient Api
@inject UserPreferencesService Prefs
@inject IJSRuntime JS
@rendermode InteractiveWebAssembly

<PageTitle>Race @RaceNumber</PageTitle>

<nav class="breadcrumb">
    <a href="/sessions">Sessions</a> &rsaquo;
    <a href="/sessions/@SessionId">Session @SessionId</a> &rsaquo;
    <span>Race @RaceNumber</span>
</nav>

@if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load race data</strong>
            <p>@_error</p>
        </div>
    </div>
}
else if (_loadingMap)
{
    <p><em>Loading race data…</em></p>
}
else if (_raceDetail is null)
{
    <p>Race not found.</p>
}
else
{
    <!-- Map section -->
    <div class="race-map-container">
        <LeafletMap @ref="_leafletMap"
                    Positions="_positions"
                    CourseLegs="_courseLegs"
                    PinEnd="_raceDetail.PinEnd"
                    BoatEnd="_raceDetail.BoatEnd"
                    WindowStart="_windowStart"
                    WindowEnd="_windowEnd"
                    OnTrackClicked="OnMapTrackClicked" />
    </div>

    <!-- Time window slicer -->
    <TimeWindowSlicer @ref="_timeWindowSlicer"
                      Positions="_positions"
                      OnWindowChanged="OnWindowChanged" />

    <!-- Timeline slicer -->
    <TimelineSlicer @ref="_timelineSlicer"
                    Positions="_positions"
                    OnTimestampChanged="OnTimelineChanged" />

    <!-- Mode toggle -->
    <div class="mode-toggle">
        <button class="@(_mode == ViewMode.Historical ? "active" : "")" @onclick="() => SetMode(ViewMode.Historical)">
            Historical
        </button>
        <button class="@(_mode == ViewMode.Current ? "active" : "")" @onclick="() => SetMode(ViewMode.Current)">
            Current
        </button>
    </div>

    @if (_chartsError is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <strong>Unable to load telemetry</strong>
                <p>@_chartsError</p>
            </div>
        </div>
    }
    else if (_loadingCharts)
    {
        <p><em>Loading telemetry…</em></p>
    }
    else if (_mode == ViewMode.Historical)
    {
        <!-- Historical mode: line charts with synced cursor -->
        <div class="charts-container">
            <TelemetryCharts @ref="_charts"
                             Charts="_chartPanels"
                             OnCursorMoved="OnChartCursorMoved" />
        </div>
    }
    else
    {
        <!-- Current mode: gauge readouts -->
        <div class="gauges-grid">
            <SpeedGauge Label="SOG" Unit="@UnitConverter.SpeedLabel(Prefs.SpeedUnit)" Value="_currentSog" />
            <HeadingGauge Value="_currentHeading" />
            <AngleGauge Label="Heel" Mode="AngleGauge.AngleMode.Heel" Value="_currentHeel" />
            <AngleGauge Label="Trim" Mode="AngleGauge.AngleMode.Trim" Value="_currentTrim" />
        </div>
    }
}

@code {
    [Parameter] public int SessionId { get; set; }
    [Parameter] public int RaceNumber { get; set; }

    private enum ViewMode { Historical, Current }
    private ViewMode _mode = ViewMode.Historical;

    // Raw API data
    private RaceDetailDto? _raceDetail;
    private List<PositionDto>? _positions;
    private List<CourseLegDto>? _courseLegs;

    // Derived chart data
    private List<ChartPanelConfig>? _chartPanels;

    // Current mode values
    private double? _currentSog;
    private double? _currentHeading;
    private double? _currentHeel;
    private double? _currentTrim;

    // Component references
    private LeafletMap? _leafletMap;
    private TelemetryCharts? _charts;
    private TimelineSlicer? _timelineSlicer;
    private TimeWindowSlicer? _timeWindowSlicer;

    // Time-window state
    private DateTimeOffset _windowStart;
    private DateTimeOffset _windowEnd;

    private bool _loadingMap = true;
    private bool _loadingCharts = true;
    private string? _error;
    private string? _chartsError;

    protected override async Task OnInitializedAsync()
    {
        await Prefs.LoadAsync();

        // Start all tasks in parallel
        var raceTask = Api.GetRaceDetailAsync(SessionId, RaceNumber);
        var posTask = Api.GetPositionsAsync(SessionId, RaceNumber);

        try
        {
            // Phase 1: map critical path — show the track as soon as possible
            await Task.WhenAll(raceTask, posTask);

            _raceDetail = raceTask.Result;
            _positions = posTask.Result;
            _loadingMap = false;

            // Initialise window to full race extent
            if (_positions is { Count: > 0 })
            {
                _windowStart = _positions[0].Time;
                _windowEnd = _positions[^1].Time;
            }

            StateHasChanged();


            if (_raceDetail?.CourseId.HasValue == true)
            {
                var course = await Api.GetCourseAsync(_raceDetail.CourseId.Value);
                _courseLegs = course?.Legs;
            }

            ComputeDerivedChannels(_windowStart, _windowEnd);
        }
        catch (HttpRequestException ex)
        {
            if (_loadingMap)
            {
                _error = "Could not reach the API. Please check that the server is running and try again.";
                _loadingMap = false;
            }
            else
            {
                _chartsError = $"Could not load telemetry data: {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            if (_loadingMap)
            {
                _error = $"An unexpected error occurred: {ex.Message}";
                _loadingMap = false;
            }
            else
            {
                _chartsError = $"An unexpected error occurred: {ex.Message}";
            }
        }
        finally
        {
            _loadingCharts = false;
        }
    }

    private void ComputeDerivedChannels(DateTimeOffset windowStart, DateTimeOffset windowEnd)
    {
        if (_positions is null || _positions.Count == 0) return;

        // Filter positions to the selected time window
        var windowedPositions = _positions
            .Where(p => p.Time >= windowStart && p.Time <= windowEnd)
            .ToList();

        if (windowedPositions.Count == 0) return;

        // Downsample positions for chart display to avoid overwhelming the browser.
        // Keep every Nth point so we land at roughly MaxChartPoints entries.
        const int MaxChartPoints = 500;
        int step = Math.Max(1, windowedPositions.Count / MaxChartPoints);
        var sampledPositions = new List<PositionDto>(windowedPositions.Count / step + 1);
        for (int i = 0; i < windowedPositions.Count; i += step)
            sampledPositions.Add(windowedPositions[i]);
        // Always include the last point so the time range is complete
        if (sampledPositions[^1] != windowedPositions[^1])
            sampledPositions.Add(windowedPositions[^1]);

        var speedData = new List<ChartDataPoint>();
        var heelData = new List<ChartDataPoint>();
        var trimData = new List<ChartDataPoint>();
        var headingData = new List<ChartDataPoint>();

        foreach (var pos in sampledPositions)
        {
            var time = pos.Time.UtcDateTime.ToString("yyyy-MM-ddTHH:mm:ss.fffZ");
            var cogDeg = pos.CourseOverGround * (180.0 / Math.PI);
            var heel = TelemetryMath.ComputeHeel(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
            var trim = TelemetryMath.ComputeTrim(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);

            var speedPt = new ChartDataPoint { Time = time };
            var sogKnots = pos.SpeedOverGround * 1.94384;
            speedPt.Values["sog"] = double.IsFinite(sogKnots)
                ? UnitConverter.ConvertSpeed(sogKnots, Prefs.SpeedUnit)
                : 0.0;
            speedData.Add(speedPt);

            var heelPt = new ChartDataPoint { Time = time };
            heelPt.Values["heel"] = heel;
            heelData.Add(heelPt);

            var trimPt = new ChartDataPoint { Time = time };
            trimPt.Values["trim"] = trim;
            trimData.Add(trimPt);

            var headingPt = new ChartDataPoint { Time = time };
            headingPt.Values["cog"] = cogDeg;
            headingData.Add(headingPt);
        }

        _chartPanels =
        [
            new ChartPanelConfig
            {
                YAxisLabel = $"SOG ({UnitConverter.SpeedLabel(Prefs.SpeedUnit)})",
                Series = [new ChartSeriesConfig { Name = "SOG", ValueField = "sog", Color = "#457b9d" }],
                Data = speedData
            },
            new ChartPanelConfig
            {
                YAxisLabel = "Heel (\u00b0)",
                Series = [new ChartSeriesConfig { Name = "Heel", ValueField = "heel", Color = "#f4a261" }],
                Data = heelData
            },
            new ChartPanelConfig
            {
                YAxisLabel = "Trim (\u00b0)",
                Series = [new ChartSeriesConfig { Name = "Trim", ValueField = "trim", Color = "#264653" }],
                Data = trimData
            },
            new ChartPanelConfig
            {
                YAxisLabel = "Heading (\u00b0)",
                Series =
                [
                    new ChartSeriesConfig { Name = "COG", ValueField = "cog", Color = "#6a4c93" },
                    new ChartSeriesConfig { Name = "True Hdg", ValueField = "trueHeading", Color = "#1982c4" }
                ],
                Data = headingData
            }
        ];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Push the correct m/s → preferred-unit factor to the JS resampler so that
            // dragging the time-window slider applies the same conversion as the C# charts.
            await JS.InvokeVoidAsync("timeWindowInterop.setSogConversion",
                UnitConverter.ConvertSpeed(1.94384, Prefs.SpeedUnit));
        }
    }

    private void SetMode(ViewMode mode)
    {
        _mode = mode;
    }

    private Task OnWindowChanged((DateTimeOffset Start, DateTimeOffset End) window)
    {
        _windowStart = window.Start;
        _windowEnd = window.End;

        // Chart data + axis zoom + map highlight are already handled in JS
        // (timeWindowInterop.resampleAndPush). We only update Blazor state
        // so the LeafletMap WindowStart/WindowEnd parameters stay in sync.
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnChartCursorMoved(string isoTimestamp)
    {
        if (!DateTimeOffset.TryParse(isoTimestamp, out var ts)) return;

        UpdateCurrentValues(ts);

        // Update map cursor
        if (_leafletMap is not null && _positions is { Count: > 0 })
        {
            var nearest = FindNearestPosition(ts);
            if (nearest is not null)
            {
                await _leafletMap.UpdateCursorAsync(nearest.Latitude, nearest.Longitude);
            }
        }

        // Sync timeline slider
        if (_timelineSlicer is not null)
            await _timelineSlicer.SetTimestampAsync(ts);

        StateHasChanged();
    }

    private async Task OnMapTrackClicked(string isoTimestamp)
    {
        if (!DateTimeOffset.TryParse(isoTimestamp, out var ts)) return;

        UpdateCurrentValues(ts);

        // Move the boat cursor directly so it works even if timelineInterop isn't ready yet.
        if (_leafletMap is not null && _positions is { Count: > 0 })
        {
            var nearest = FindNearestPosition(ts);
            if (nearest is not null)
                await _leafletMap.UpdateCursorAsync(nearest.Latitude, nearest.Longitude);
        }

        // Sync charts to this timestamp
        if (_charts is not null)
        {
            await _charts.SyncCursorAsync(isoTimestamp);
        }

        // Sync timeline slider
        if (_timelineSlicer is not null)
            await _timelineSlicer.SetTimestampAsync(ts);

        StateHasChanged();
    }

    private void OnTimelineChanged(DateTimeOffset ts)
    {
        UpdateCurrentValues(ts);

        // Chart cursors are now synced directly by JS (timelineInterop → echartsInterop).
        // Map cursor is already moved by JS (timelineInterop.onSliderInput).
        // Only re-render when gauges are visible so Blazor can update their values.
        if (_mode == ViewMode.Current)
        {
            StateHasChanged();
        }
    }

    private void UpdateCurrentValues(DateTimeOffset ts)
    {
        if (_positions is null || _positions.Count == 0) return;

        var pos = FindNearestPosition(ts);
        if (pos is null) return;

        _currentSog = UnitConverter.ConvertSpeed(pos.SpeedOverGround * 1.94384, Prefs.SpeedUnit);
        _currentHeading = pos.CourseOverGround * (180.0 / Math.PI);
        _currentHeel = TelemetryMath.ComputeHeel(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
        _currentTrim = TelemetryMath.ComputeTrim(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
    }

    private PositionDto? FindNearestPosition(DateTimeOffset ts)
    {
        if (_positions is null || _positions.Count == 0) return null;

        int lo = 0, hi = _positions.Count - 1;
        while (lo < hi)
        {
            int mid = (lo + hi) / 2;
            if (_positions[mid].Time < ts)
                lo = mid + 1;
            else
                hi = mid;
        }

        if (lo > 0)
        {
            var prev = _positions[lo - 1];
            var curr = _positions[lo];
            return Math.Abs((prev.Time - ts).Ticks) <= Math.Abs((curr.Time - ts).Ticks) ? prev : curr;
        }

        return _positions[lo];
    }
}
