@namespace Vakaros.Vkx.Web.Components.Gauges

<div class="gauge-card">
    <div class="gauge-label">VMG</div>
    <div class="gauge-value">
        @if (Value.HasValue)
        {
            <span class="gauge-number @(Value.Value < 0 ? "gauge-negative" : "")">@Value.Value.ToString("F1")</span>
            <span class="gauge-unit">kn</span>
        }
        else
        {
            <span class="gauge-number gauge-no-data">—</span>
        }
    </div>
</div>

@code {
    [Parameter] public double? Value { get; set; }
}
