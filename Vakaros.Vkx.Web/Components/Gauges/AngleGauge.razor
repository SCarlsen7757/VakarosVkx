@namespace Vakaros.Vkx.Web.Components.Gauges

<div class="gauge-card angle-gauge">
    <div class="gauge-header">
        <span class="gauge-label">@Label</span>
        <button class="gauge-toggle" @onclick="ToggleMode" title="Toggle view">
            @(ShowAngle ? "123" : "∠")
        </button>
    </div>

    @if (!Value.HasValue)
    {
        <div class="gauge-value">
            <span class="gauge-number gauge-no-data">—</span>
        </div>
    }
    else if (!ShowAngle)
    {
        <div class="gauge-value">
            <span class="gauge-number">@Value.Value.ToString("F1")</span>
            <span class="gauge-unit">°</span>
        </div>
    }
    else
    {
        <div class="angle-visual">
            <svg viewBox="0 0 120 120" width="120" height="120">
                @if (Mode == AngleMode.Heel)
                {
                    <!-- Heel: boat cross-section, rotated by the heel angle -->
                    <!-- Water line (fixed horizon) -->
                    <line x1="10" y1="70" x2="110" y2="70" stroke="#457b9d" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.5" />

                    <!-- Boat cross-section (rotated) -->
                    <g transform="rotate(@(ClampedAngle), 60, 60)">
                        <!-- Hull -->
                        <path d="M30,65 Q35,85 60,88 Q85,85 90,65 Z" fill="#264653" />
                        <!-- Deck -->
                        <line x1="30" y1="65" x2="90" y2="65" stroke="#2a9d8f" stroke-width="2" />
                        <!-- Mast -->
                        <line x1="60" y1="65" x2="60" y2="25" stroke="#e9c46a" stroke-width="2.5" />
                    </g>

                    <!-- Angle readout -->
                    @((MarkupString)$"<text x='60' y='115' text-anchor='middle' fill='currentColor' font-size='11'>{Value.Value.ToString("F1")}°</text>")
                }
                else
                {
                    <!-- Trim: boat side-profile, rotated by the pitch angle -->
                    <!-- Water line (fixed horizon) -->
                    <line x1="10" y1="70" x2="110" y2="70" stroke="#457b9d" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.5" />

                    <!-- Boat side-profile (rotated) -->
                    <g transform="rotate(@(ClampedAngle), 60, 65)">
                        <!-- Hull side profile -->
                        <path d="M15,65 Q20,80 60,82 Q100,80 105,65 Q100,62 60,60 Q20,62 15,65 Z" fill="#264653" />
                        <!-- Deck line -->
                        <line x1="20" y1="63" x2="100" y2="63" stroke="#2a9d8f" stroke-width="1.5" />
                        <!-- Bow marker -->
                        <circle cx="100" cy="63" r="2.5" fill="#e63946" />
                        <!-- Mast -->
                        <line x1="45" y1="63" x2="45" y2="30" stroke="#e9c46a" stroke-width="2" />
                    </g>

                    <!-- Angle readout -->
                    @((MarkupString)$"<text x='60' y='115' text-anchor='middle' fill='currentColor' font-size='11'>{Value.Value.ToString("F1")}°</text>")
                }
            </svg>
        </div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "Heel";
    [Parameter] public AngleMode Mode { get; set; } = AngleMode.Heel;
    [Parameter] public double? Value { get; set; }

    private bool ShowAngle { get; set; } = true;

    private double ClampedAngle => Value.HasValue ? Math.Clamp(Value.Value, -45, 45) : 0;

    private void ToggleMode() => ShowAngle = !ShowAngle;

    public enum AngleMode
    {
        Heel,
        Trim
    }
}
