@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="@_mapElementId" style="height:100%;width:100%;min-height:400px;"></div>

@code {
    [Parameter] public List<Vakaros.Vkx.Shared.Dtos.Telemetry.PositionDto>? Positions { get; set; }
    [Parameter] public List<Vakaros.Vkx.Shared.Dtos.Courses.CourseLegDto>? CourseLegs { get; set; }
    [Parameter] public Vakaros.Vkx.Shared.Dtos.Races.LinePositionDto? PinEnd { get; set; }
    [Parameter] public Vakaros.Vkx.Shared.Dtos.Races.LinePositionDto? BoatEnd { get; set; }
    [Parameter] public EventCallback<string> OnTrackClicked { get; set; }

    private readonly string _mapElementId = $"leaflet-map-{Guid.NewGuid():N}";
    private DotNetObjectReference<LeafletMap>? _dotNetRef;
    private bool _mapInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("leafletInterop.initMap", _mapElementId);
            _mapInitialized = true;
            await RenderMapDataAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_mapInitialized)
        {
            await RenderMapDataAsync();
        }
    }

    private async Task RenderMapDataAsync()
    {
        if (Positions is { Count: > 0 })
        {
            await JS.InvokeVoidAsync("leafletInterop.addBoatTrack", Positions, _dotNetRef, nameof(OnMapTrackClick));
        }

        if (CourseLegs is { Count: > 0 })
        {
            await JS.InvokeVoidAsync("leafletInterop.addCourseMarks", CourseLegs);
        }

        if (PinEnd is not null && BoatEnd is not null)
        {
            await JS.InvokeVoidAsync("leafletInterop.addStartLine", PinEnd, BoatEnd);
        }
    }

    public async Task UpdateCursorAsync(double lat, double lng)
    {
        if (_mapInitialized)
        {
            await JS.InvokeVoidAsync("leafletInterop.updateCursorPosition", lat, lng);
        }
    }

    [JSInvokable]
    public async Task OnMapTrackClick(string timestamp)
    {
        await OnTrackClicked.InvokeAsync(timestamp);
    }

    public async ValueTask DisposeAsync()
    {
        if (_mapInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("leafletInterop.dispose");
            }
            catch
            {
                // Ignore JS interop errors during disposal
            }

        }
        _dotNetRef?.Dispose();
    }
}
