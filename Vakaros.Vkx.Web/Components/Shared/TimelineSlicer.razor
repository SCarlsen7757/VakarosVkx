@inject IJSRuntime JS
@implements IAsyncDisposable

<div id="@_containerId" class="timeline-slicer">
    <div class="timeline-slicer-labels">
        <span class="timeline-time">--:--:--</span>
        <span class="timeline-current">--:--:--</span>
        <span class="timeline-time">--:--:--</span>
    </div>
    <input type="range" class="timeline-slider" min="0" max="0" value="0" />
</div>

@code {
    [Parameter] public List<PositionDto>? Positions { get; set; }
    [Parameter] public EventCallback<DateTimeOffset> OnTimestampChanged { get; set; }

    private readonly string _containerId = $"timeline-{Guid.NewGuid():N}";
    private DotNetObjectReference<TimelineSlicer>? _dotNetRef;
    private bool _jsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Positions is { Count: > 0 })
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("timelineInterop.init",
                _containerId, Positions, _dotNetRef, nameof(OnSliderChanged));
            _jsInitialized = true;
        }
    }

    /// <summary>
    /// Sets the slider position from an external source (map click, chart cursor).
    /// Goes through JS so the slider updates instantly without Blazor re-rendering.
    /// </summary>
    public async Task SetTimestampAsync(DateTimeOffset ts)
    {
        if (_jsInitialized)
        {
            await JS.InvokeVoidAsync("timelineInterop.setTimestamp", ts.ToString("O"));
        }
    }

    [JSInvokable]
    public async Task OnSliderChanged(string isoTimestamp)
    {
        if (DateTimeOffset.TryParse(isoTimestamp, out var ts))
        {
            await OnTimestampChanged.InvokeAsync(ts);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("timelineInterop.dispose");
            }
            catch
            {
                // Ignore any errors during disposal
            }
        }
        _dotNetRef?.Dispose();
    }
}
