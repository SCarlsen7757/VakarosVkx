@page "/marks"
@inject VakarosApiClient Api
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Marks</PageTitle>

<h1>Marks</h1>

@if (_loading)
{
    <p><em>Loading marks…</em></p>
}
else if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load marks</strong>
            <p>@_error</p>
        </div>
    </div>
}
else
{
    <button class="btn btn-primary" @onclick="StartCreate" disabled="@(_editingId is not null)">+ New Mark</button>

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Latitude</th>
                <th>Longitude</th>
                <th>Active From</th>
                <th>Active Until</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (_creating)
            {
                <tr>
                    <td><input @bind="_formName" placeholder="Name" /></td>
                    <td><input type="number" step="0.000001" @bind="_formLat" /></td>
                    <td><input type="number" step="0.000001" @bind="_formLon" /></td>
                    <td><input type="date" @bind="_formActiveFrom" /></td>
                    <td><input type="date" @bind="_formActiveUntil" /></td>
                    <td><input @bind="_formDescription" placeholder="Description" /></td>
                    <td>
                        <button class="btn btn-sm" @onclick="SaveCreate">Save</button>
                        <button class="btn btn-sm" @onclick="CancelEdit">Cancel</button>
                    </td>
                </tr>
            }

            @if (_marks is not null)
            {
                @foreach (var mark in _marks)
                {
                    @if (_editingId == mark.Id)
                    {
                        <tr>
                            <td><input @bind="_formName" /></td>
                            <td><input type="number" step="0.000001" @bind="_formLat" /></td>
                            <td><input type="number" step="0.000001" @bind="_formLon" /></td>
                            <td><input type="date" @bind="_formActiveFrom" /></td>
                            <td><input type="date" @bind="_formActiveUntil" /></td>
                            <td><input @bind="_formDescription" /></td>
                            <td>
                                <button class="btn btn-sm" @onclick="SaveEdit">Save</button>
                                <button class="btn btn-sm" @onclick="CancelEdit">Cancel</button>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@mark.Name</td>
                            <td>@mark.Latitude.ToString("F6")</td>
                            <td>@mark.Longitude.ToString("F6")</td>
                            <td>@mark.ActiveFrom.ToString("yyyy-MM-dd")</td>
                            <td>@(mark.ActiveUntil?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td>@(mark.Description ?? "—")</td>
                            <td>
                                <button class="btn btn-sm" @onclick="() => StartEdit(mark)" disabled="@(_editingId is not null || _creating)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(mark)" disabled="@(_editingId is not null || _creating)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>

    @if (_marks is { Count: 0 } && !_creating)
    {
        <p>No marks found. Click <strong>+ New Mark</strong> to create one.</p>
    }

    @if (_actionError is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <p>@_actionError</p>
            </div>
        </div>
    }
}

@code {
    private List<MarkDto>? _marks;
    private bool _loading = true;
    private string? _error;
    private string? _actionError;

    // Form state
    private bool _creating;
    private int? _editingId;
    private string _formName = "";
    private double _formLat;
    private double _formLon;
    private DateOnly _formActiveFrom = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _formActiveUntil;
    private string? _formDescription;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _marks = await Api.GetMarksAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartCreate()
    {
        _actionError = null;
        _creating = true;
        _formName = "";
        _formLat = 0;
        _formLon = 0;
        _formActiveFrom = DateOnly.FromDateTime(DateTime.Today);
        _formActiveUntil = null;
        _formDescription = null;
    }

    private void StartEdit(MarkDto mark)
    {
        _actionError = null;
        _editingId = mark.Id;
        _formName = mark.Name;
        _formLat = mark.Latitude;
        _formLon = mark.Longitude;
        _formActiveFrom = mark.ActiveFrom;
        _formActiveUntil = mark.ActiveUntil;
        _formDescription = mark.Description;
    }

    private void CancelEdit()
    {
        _creating = false;
        _editingId = null;
        _actionError = null;
    }

    private async Task SaveCreate()
    {
        _actionError = null;
        if (string.IsNullOrWhiteSpace(_formName))
        {
            _actionError = "Name is required.";
            return;
        }

        try
        {
            var request = new CreateMarkRequest(_formName.Trim(), _formActiveFrom, _formActiveUntil, _formLat, _formLon, _formDescription?.Trim());
            var created = await Api.CreateMarkAsync(request);
            if (created is not null)
            {
                _marks ??= [];
                _marks.Add(created);
            }
            _creating = false;
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to create mark: {ex.Message}";
        }
    }

    private async Task SaveEdit()
    {
        _actionError = null;
        if (_editingId is null || string.IsNullOrWhiteSpace(_formName))
        {
            _actionError = "Name is required.";
            return;
        }

        try
        {
            var request = new UpdateMarkRequest(_formName.Trim(), _formActiveFrom, _formActiveUntil, _formLat, _formLon, _formDescription?.Trim());
            var updated = await Api.UpdateMarkAsync(_editingId.Value, request);
            if (updated is not null && _marks is not null)
            {
                var idx = _marks.FindIndex(m => m.Id == _editingId.Value);
                if (idx >= 0) _marks[idx] = updated;
            }
            _editingId = null;
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to update mark: {ex.Message}";
        }
    }

    private async Task Delete(MarkDto mark)
    {
        _actionError = null;
        try
        {
            await Api.DeleteMarkAsync(mark.Id);
            _marks?.RemoveAll(m => m.Id == mark.Id);
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to delete mark: {ex.Message}";
        }
    }
}
