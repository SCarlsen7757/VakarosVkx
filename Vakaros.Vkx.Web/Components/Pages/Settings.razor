@page "/settings"
@inject UserPreferencesService Prefs
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Settings</PageTitle>

<h1>Settings</h1>

@if (!_loaded)
{
    <p><em>Loading preferences…</em></p>
}
else
{
    <section class="settings-section">
        <h2>Display Units</h2>

        <div class="settings-field">
            <label for="speed-unit">Boat Speed</label>
            <select id="speed-unit" value="@Prefs.SpeedUnit" @onchange="OnSpeedUnitChanged">
                <option value="@SpeedUnit.Knots">Knots (kn)</option>
                <option value="@SpeedUnit.KmPerHour">Kilometres per hour (km/h)</option>
            </select>
        </div>

        <div class="settings-field">
            <label for="wind-unit">Wind Speed</label>
            <select id="wind-unit" value="@Prefs.WindSpeedUnit" @onchange="OnWindSpeedUnitChanged">
                <option value="@WindSpeedUnit.MetersPerSecond">Metres per second (m/s)</option>
                <option value="@WindSpeedUnit.Knots">Knots (kn)</option>
            </select>
        </div>

        <div class="settings-field">
            <label for="distance-unit">Course Length</label>
            <select id="distance-unit" value="@Prefs.DistanceUnit" @onchange="OnDistanceUnitChanged">
                <option value="@DistanceUnit.Meters">Metres (m)</option>
                <option value="@DistanceUnit.Kilometers">Kilometres (km)</option>
                <option value="@DistanceUnit.NauticalMiles">Nautical miles (NM)</option>
            </select>
        </div>

        @if (_saved)
        {
            <p class="settings-saved">✓ Preferences saved</p>
        }
    </section>
}

@code {
    private bool _loaded;
    private bool _saved;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Prefs.LoadAsync();
            _loaded = true;
            StateHasChanged();
        }
    }

    private async Task OnSpeedUnitChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<SpeedUnit>(e.Value?.ToString(), out var unit))
        {
            await Prefs.SetSpeedUnitAsync(unit);
            await ShowSaved();
        }
    }

    private async Task OnWindSpeedUnitChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<WindSpeedUnit>(e.Value?.ToString(), out var unit))
        {
            await Prefs.SetWindSpeedUnitAsync(unit);
            await ShowSaved();
        }
    }

    private async Task OnDistanceUnitChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<DistanceUnit>(e.Value?.ToString(), out var unit))
        {
            await Prefs.SetDistanceUnitAsync(unit);
            await ShowSaved();
        }
    }

    private async Task ShowSaved()
    {
        _saved = true;
        StateHasChanged();
        await Task.Delay(2000);
        _saved = false;
        StateHasChanged();
    }
}
