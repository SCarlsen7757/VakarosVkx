@page "/boats"
@using Vakaros.Vkx.Shared.Dtos.BoatClasses
@inject VakarosApiClient Api
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Boats</PageTitle>

<h1>Boats</h1>

@if (_loading)
{
    <p><em>Loading boats…</em></p>
}
else if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load boats</strong>
            <p>@_error</p>
        </div>
    </div>
}
else
{
    <button class="btn btn-primary" @onclick="StartCreate" disabled="@(_editingId is not null)">+ New Boat</button>

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Sail Number</th>
                <th>Boat Class</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (_creating)
            {
                <tr>
                    <td><input @bind="_formName" placeholder="Name" /></td>
                    <td><input @bind="_formSailNumber" placeholder="Sail number" /></td>
                    <td>
                        <select @bind="_formBoatClassId">
                            <option value="0">— select —</option>
                            @if (_boatClasses is not null)
                            {
                                @foreach (var bc in _boatClasses)
                                {
                                    <option value="@bc.Id">@bc.Name</option>
                                }
                            }
                        </select>
                    </td>
                    <td><input @bind="_formDescription" placeholder="Description" /></td>
                    <td>
                        <button class="btn btn-sm" @onclick="SaveCreate">Save</button>
                        <button class="btn btn-sm" @onclick="CancelEdit">Cancel</button>
                    </td>
                </tr>
            }

            @if (_boats is not null)
            {
                @foreach (var boat in _boats)
                {
                    @if (_editingId == boat.Id)
                    {
                        <tr>
                            <td><input @bind="_formName" /></td>
                            <td><input @bind="_formSailNumber" /></td>
                            <td>
                                <select @bind="_formBoatClassId">
                                    <option value="0">— select —</option>
                                    @if (_boatClasses is not null)
                                    {
                                        @foreach (var bc in _boatClasses)
                                        {
                                            <option value="@bc.Id">@bc.Name</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td><input @bind="_formDescription" /></td>
                            <td>
                                <button class="btn btn-sm" @onclick="SaveEdit">Save</button>
                                <button class="btn btn-sm" @onclick="CancelEdit">Cancel</button>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@boat.Name</td>
                            <td>@(boat.SailNumber ?? "—")</td>
                            <td>@boat.BoatClass.Name</td>
                            <td>@(boat.Description ?? "—")</td>
                            <td>
                                <button class="btn btn-sm" @onclick="() => StartEdit(boat)" disabled="@(_editingId is not null || _creating)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(boat)" disabled="@(_editingId is not null || _creating)">Delete</button>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>

    @if (_boats is { Count: 0 } && !_creating)
    {
        <p>No boats found. Click <strong>+ New Boat</strong> to create one.</p>
    }

    @if (_actionError is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <p>@_actionError</p>
            </div>
        </div>
    }
}

@code {
    private List<BoatDto>? _boats;
    private List<BoatClassSummaryDto>? _boatClasses;
    private bool _loading = true;
    private string? _error;
    private string? _actionError;

    // Form state
    private bool _creating;
    private int? _editingId;
    private string _formName = "";
    private string? _formSailNumber;
    private int _formBoatClassId;
    private string? _formDescription;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var boatsTask = Api.GetBoatsAsync();
            var classesTask = Api.GetBoatClassesAsync();
            await Task.WhenAll(boatsTask, classesTask);
            _boats = boatsTask.Result;
            _boatClasses = classesTask.Result;
        }
        catch (HttpRequestException)
        {
            _error = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartCreate()
    {
        _actionError = null;
        _creating = true;
        _formName = "";
        _formSailNumber = null;
        _formBoatClassId = 0;
        _formDescription = null;
    }

    private void StartEdit(BoatDto boat)
    {
        _actionError = null;
        _editingId = boat.Id;
        _formName = boat.Name;
        _formSailNumber = boat.SailNumber;
        _formBoatClassId = boat.BoatClass.Id;
        _formDescription = boat.Description;
    }

    private void CancelEdit()
    {
        _creating = false;
        _editingId = null;
        _actionError = null;
    }

    private async Task SaveCreate()
    {
        _actionError = null;
        if (string.IsNullOrWhiteSpace(_formName) || _formBoatClassId == 0)
        {
            _actionError = "Name and Boat Class are required.";
            return;
        }

        try
        {
            var request = new CreateBoatRequest(_formName.Trim(), _formSailNumber?.Trim(), _formBoatClassId, _formDescription?.Trim());
            var created = await Api.CreateBoatAsync(request);
            if (created is not null)
            {
                _boats ??= [];
                _boats.Add(created);
            }
            _creating = false;
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to create boat: {ex.Message}";
        }
    }

    private async Task SaveEdit()
    {
        _actionError = null;
        if (_editingId is null || string.IsNullOrWhiteSpace(_formName) || _formBoatClassId == 0)
        {
            _actionError = "Name and Boat Class are required.";
            return;
        }

        try
        {
            var request = new UpdateBoatRequest(_formName.Trim(), _formSailNumber?.Trim(), _formBoatClassId, _formDescription?.Trim());
            var updated = await Api.UpdateBoatAsync(_editingId.Value, request);
            if (updated is not null && _boats is not null)
            {
                var idx = _boats.FindIndex(b => b.Id == _editingId.Value);
                if (idx >= 0) _boats[idx] = updated;
            }
            _editingId = null;
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to update boat: {ex.Message}";
        }
    }

    private async Task Delete(BoatDto boat)
    {
        _actionError = null;
        try
        {
            await Api.DeleteBoatAsync(boat.Id);
            _boats?.RemoveAll(b => b.Id == boat.Id);
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to delete boat: {ex.Message}";
        }
    }
}
