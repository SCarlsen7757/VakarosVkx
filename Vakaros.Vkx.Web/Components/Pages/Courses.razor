@page "/courses"
@inject VakarosApiClient Api
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Courses</PageTitle>

<h1>Courses</h1>

@if (_loading)
{
    <p><em>Loading courses…</em></p>
}
else if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load courses</strong>
            <p>@_error</p>
        </div>
    </div>
}
else
{
    <button class="btn btn-primary" @onclick="StartCreate" disabled="@_editing">+ New Course</button>

    @if (_editing)
    {
        <div class="edit-form-panel">
            <h3>@(_editingId is null ? "Create Course" : "Edit Course")</h3>

            <div class="form-row">
                <label>Name</label>
                <input @bind="_formName" placeholder="Name" />
            </div>
            <div class="form-row">
                <label>Year</label>
                <input type="number" @bind="_formYear" />
            </div>
            <div class="form-row">
                <label>Description</label>
                <input @bind="_formDescription" placeholder="Description" />
            </div>

            <h4>Legs</h4>
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mark</th>
                        <th>Leg Name</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < _formLegs.Count; i++)
                    {
                        var idx = i;
                        <tr>
                            <td>@(idx + 1)</td>
                            <td>
                                <select @bind="_formLegs[idx].MarkId">
                                    <option value="0">— select mark —</option>
                                    @if (_marks is not null)
                                    {
                                        @foreach (var m in _marks)
                                        {
                                            <option value="@m.Id">@m.Name</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td><input @bind="_formLegs[idx].LegName" placeholder="Leg name" /></td>
                            <td>
                                <button class="btn btn-sm" @onclick="() => MoveLegUp(idx)" disabled="@(idx == 0)">↑</button>
                                <button class="btn btn-sm" @onclick="() => MoveLegDown(idx)" disabled="@(idx == _formLegs.Count - 1)">↓</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => _formLegs.RemoveAt(idx)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <button class="btn btn-sm" @onclick="AddLegRow">+ Add Leg</button>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveForm">Save</button>
                <button class="btn" @onclick="CancelEdit">Cancel</button>
            </div>
        </div>
    }

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Year</th>
                <th>Legs</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (_courses is not null)
            {
                @foreach (var c in _courses)
                {
                    <tr>
                        <td>@c.Name</td>
                        <td>@c.Year</td>
                        <td>@c.LegCount</td>
                        <td>@(c.Description ?? "—")</td>
                        <td>
                            <button class="btn btn-sm" @onclick="() => StartEditAsync(c)" disabled="@_editing">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(c)" disabled="@_editing">Delete</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @if (_courses is { Count: 0 } && !_editing)
    {
        <p>No courses found. Click <strong>+ New Course</strong> to create one.</p>
    }

    @if (_actionError is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <p>@_actionError</p>
            </div>
        </div>
    }
}

@code {
    private List<CourseSummaryDto>? _courses;
    private List<MarkDto>? _marks;
    private bool _loading = true;
    private string? _error;
    private string? _actionError;

    // Form state
    private bool _editing;
    private int? _editingId;
    private string _formName = "";
    private int _formYear = DateTime.Today.Year;
    private string? _formDescription;
    private List<LegFormRow> _formLegs = [];

    private class LegFormRow
    {
        public int MarkId { get; set; }
        public string? LegName { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var coursesTask = Api.GetCoursesAsync();
            var marksTask = Api.GetMarksAsync();
            await Task.WhenAll(coursesTask, marksTask);
            _courses = coursesTask.Result;
            _marks = marksTask.Result;
        }
        catch (HttpRequestException)
        {
            _error = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartCreate()
    {
        _actionError = null;
        _editing = true;
        _editingId = null;
        _formName = "";
        _formYear = DateTime.Today.Year;
        _formDescription = null;
        _formLegs = [];
    }

    private async Task StartEditAsync(CourseSummaryDto summary)
    {
        _actionError = null;
        try
        {
            var full = await Api.GetCourseAsync(summary.Id);
            if (full is null)
            {
                _actionError = "Could not load course details.";
                return;
            }

            _editing = true;
            _editingId = full.Id;
            _formName = full.Name;
            _formYear = full.Year;
            _formDescription = full.Description;
            _formLegs = full.Legs
                .OrderBy(l => l.SortOrder)
                .Select(l => new LegFormRow { MarkId = l.MarkId, LegName = l.LegName })
                .ToList();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to load course: {ex.Message}";
        }
    }

    private void CancelEdit()
    {
        _editing = false;
        _editingId = null;
        _actionError = null;
    }

    private void AddLegRow()
    {
        _formLegs.Add(new LegFormRow());
    }

    private void MoveLegUp(int idx)
    {
        if (idx <= 0) return;
        (_formLegs[idx], _formLegs[idx - 1]) = (_formLegs[idx - 1], _formLegs[idx]);
    }

    private void MoveLegDown(int idx)
    {
        if (idx >= _formLegs.Count - 1) return;
        (_formLegs[idx], _formLegs[idx + 1]) = (_formLegs[idx + 1], _formLegs[idx]);
    }

    private async Task SaveForm()
    {
        _actionError = null;
        if (string.IsNullOrWhiteSpace(_formName))
        {
            _actionError = "Name is required.";
            return;
        }

        var legs = _formLegs
            .Where(l => l.MarkId > 0)
            .Select(l => new CourseLegRequest(l.MarkId, l.LegName?.Trim()))
            .ToList();

        try
        {
            if (_editingId is null)
            {
                var request = new CreateCourseRequest(_formName.Trim(), _formYear, _formDescription?.Trim(), legs);
                await Api.CreateCourseAsync(request);
            }
            else
            {
                var request = new UpdateCourseRequest(_formName.Trim(), _formYear, _formDescription?.Trim(), legs);
                await Api.UpdateCourseAsync(_editingId.Value, request);
            }

            // Reload the list
            _courses = await Api.GetCoursesAsync();
            _editing = false;
            _editingId = null;
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to save course: {ex.Message}";
        }
    }

    private async Task Delete(CourseSummaryDto course)
    {
        _actionError = null;
        try
        {
            await Api.DeleteCourseAsync(course.Id);
            _courses?.RemoveAll(c => c.Id == course.Id);
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to delete course: {ex.Message}";
        }
    }
}
