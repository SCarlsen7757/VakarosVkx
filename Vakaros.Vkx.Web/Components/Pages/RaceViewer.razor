@page "/sessions/{SessionId:int}/races/{RaceNumber:int}"
@using Vakaros.Vkx.Shared.Dtos
@using Vakaros.Vkx.Web.Components.Charts
@using Vakaros.Vkx.Web.Components.Gauges
@using Vakaros.Vkx.Web.Components.Map
@using Vakaros.Vkx.Web.Components.Shared
@using Vakaros.Vkx.Web.Services
@inject VakarosApiClient Api
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Race @RaceNumber</PageTitle>

<nav class="breadcrumb">
    <a href="/sessions">Sessions</a> &rsaquo;
    <a href="/sessions/@SessionId">Session @SessionId</a> &rsaquo;
    <span>Race @RaceNumber</span>
</nav>

@if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load race data</strong>
            <p>@_error</p>
        </div>
    </div>
}
else if (_loadingMap)
{
    <p><em>Loading race data…</em></p>
}
else if (_raceDetail is null)
{
    <p>Race not found.</p>
}
else
{
    <!-- Map section -->
    <div class="race-map-container">
        <LeafletMap @ref="_leafletMap"
                    Positions="_positions"
                    CourseLegs="_courseLegs"
                    PinEnd="_raceDetail.PinEnd"
                    BoatEnd="_raceDetail.BoatEnd"
                    OnTrackClicked="OnMapTrackClicked" />
    </div>

    <!-- Timeline slicer -->
    <TimelineSlicer @ref="_timelineSlicer"
                    Positions="_positions"
                    OnTimestampChanged="OnTimelineChanged" />

    <!-- Mode toggle -->
    <div class="mode-toggle">
        <button class="@(_mode == ViewMode.Historical ? "active" : "")" @onclick="() => SetMode(ViewMode.Historical)">
            Historical
        </button>
        <button class="@(_mode == ViewMode.Current ? "active" : "")" @onclick="() => SetMode(ViewMode.Current)">
            Current
        </button>
    </div>

    @if (_chartsError is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <strong>Unable to load telemetry</strong>
                <p>@_chartsError</p>
            </div>
        </div>
    }
    else if (_loadingCharts)
    {
        <p><em>Loading telemetry…</em></p>
    }
    else if (_mode == ViewMode.Historical)
    {
        <!-- Historical mode: line charts with synced cursor -->
        <div class="charts-container">
            <TelemetryCharts @ref="_charts"
                             SpeedData="_speedData"
                             HeelData="_heelData"
                             TrimData="_trimData"
                             HeadingData="_headingData"
                             OnCursorMoved="OnChartCursorMoved" />
        </div>
    }
    else
    {
        <!-- Current mode: gauge readouts -->
        <div class="gauges-grid">
            <SpeedGauge Label="SOG" Unit="kn" Value="_currentSog" />
            <HeadingGauge Value="_currentHeading" />
            <AngleGauge Label="Heel" Mode="AngleGauge.AngleMode.Heel" Value="_currentHeel" />
            <AngleGauge Label="Trim" Mode="AngleGauge.AngleMode.Trim" Value="_currentTrim" />
        </div>
    }
}

@code {
    [Parameter] public int SessionId { get; set; }
    [Parameter] public int RaceNumber { get; set; }

    private enum ViewMode { Historical, Current }
    private ViewMode _mode = ViewMode.Historical;

    // Raw API data
    private RaceDetailDto? _raceDetail;
    private List<PositionDto>? _positions;
    private List<WindDto>? _windData;
    private List<SpeedThroughWaterDto>? _stwData;
    private List<CourseLegDto>? _courseLegs;

    // Derived chart data
    private List<TelemetryCharts.ChartDataPoint>? _speedData;
    private List<TelemetryCharts.ChartDataPoint>? _heelData;
    private List<TelemetryCharts.ChartDataPoint>? _trimData;
    private List<TelemetryCharts.ChartDataPoint>? _headingData;

    // Current mode values
    private double? _currentSog;
    private double? _currentHeading;
    private double? _currentHeel;
    private double? _currentTrim;

    // Component references
    private LeafletMap? _leafletMap;
    private TelemetryCharts? _charts;
    private TimelineSlicer? _timelineSlicer;

    private bool _loadingMap = true;
    private bool _loadingCharts = true;
    private string? _error;
    private string? _chartsError;

    protected override async Task OnInitializedAsync()
    {
        // Start all tasks in parallel
        var raceTask = Api.GetRaceDetailAsync(SessionId, RaceNumber);
        var posTask = Api.GetPositionsAsync(SessionId, RaceNumber);
        var windTask = Api.GetWindAsync(SessionId, RaceNumber);
        var stwTask = Api.GetSpeedThroughWaterAsync(SessionId, RaceNumber);

        try
        {
            // Phase 1: map critical path — show the track as soon as possible
            await Task.WhenAll(raceTask, posTask);

            _raceDetail = raceTask.Result;
            _positions = posTask.Result;
            _loadingMap = false;
            StateHasChanged();

            // Phase 2: telemetry — charts/gauges render after this completes
            await Task.WhenAll(windTask, stwTask);

            _windData = windTask.Result;
            _stwData = stwTask.Result;

            if (_raceDetail?.CourseId.HasValue == true)
            {
                var course = await Api.GetCourseAsync(_raceDetail.CourseId.Value);
                _courseLegs = course?.Legs;
            }

            ComputeDerivedChannels();
        }
        catch (HttpRequestException ex)
        {
            if (_loadingMap)
            {
                _error = "Could not reach the API. Please check that the server is running and try again.";
                _loadingMap = false;
            }
            else
            {
                _chartsError = $"Could not load telemetry data: {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            if (_loadingMap)
            {
                _error = $"An unexpected error occurred: {ex.Message}";
                _loadingMap = false;
            }
            else
            {
                _chartsError = $"An unexpected error occurred: {ex.Message}";
            }
        }
        finally
        {
            _loadingCharts = false;
        }
    }

    private void ComputeDerivedChannels()
    {
        if (_positions is null || _positions.Count == 0) return;

        // Build a lookup for wind by nearest time
        var windByTime = _windData?
            .OrderBy(w => w.Time)
            .ToList();

        // Build a lookup for STW by nearest time
        var stwByTime = _stwData?
            .OrderBy(s => s.Time)
            .ToList();

        // Downsample positions for chart display to avoid overwhelming the browser.
        // Keep every Nth point so we land at roughly MaxChartPoints entries.
        const int MaxChartPoints = 500;
        int step = Math.Max(1, _positions.Count / MaxChartPoints);
        var sampledPositions = new List<PositionDto>(_positions.Count / step + 1);
        for (int i = 0; i < _positions.Count; i += step)
            sampledPositions.Add(_positions[i]);
        // Always include the last point so the time range is complete
        if (sampledPositions[^1] != _positions[^1])
            sampledPositions.Add(_positions[^1]);

        _speedData = [];
        _heelData = [];
        _trimData = [];
        _headingData = [];

        int windIdx = 0;
        int stwIdx = 0;

        foreach (var pos in sampledPositions)
        {
            var time = pos.Time.ToString("O");
            var cogDeg = pos.CourseOverGround * (180.0 / Math.PI);

            // Speed data
            double? stwValue = null;
            if (stwByTime is { Count: > 0 })
            {
                while (stwIdx < stwByTime.Count - 1 && stwByTime[stwIdx + 1].Time <= pos.Time)
                    stwIdx++;
                stwValue = stwByTime[stwIdx].ForwardSpeed;
            }

            _speedData.Add(new TelemetryCharts.ChartDataPoint
            {
                Time = time,
                Sog = pos.SpeedOverGround,
                Stw = stwValue
            });

            // VMG
            double? vmgValue = null;
            if (windByTime is { Count: > 0 })
            {
                while (windIdx < windByTime.Count - 1 && windByTime[windIdx + 1].Time <= pos.Time)
                    windIdx++;
                vmgValue = TelemetryMath.ComputeVmg(pos.SpeedOverGround, cogDeg, windByTime[windIdx].WindDirection);
            }

            // Heel
            var heel = TelemetryMath.ComputeHeel(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
            _heelData.Add(new TelemetryCharts.ChartDataPoint { Time = time, Heel = heel });

            // Trim
            var trim = TelemetryMath.ComputeTrim(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
            _trimData.Add(new TelemetryCharts.ChartDataPoint { Time = time, Trim = trim });

            // Heading
            _headingData.Add(new TelemetryCharts.ChartDataPoint
            {
                Time = time,
                Cog = cogDeg
            });
        }
    }

    private void SetMode(ViewMode mode)
    {
        _mode = mode;
    }

    private async Task OnChartCursorMoved(string isoTimestamp)
    {
        if (!DateTimeOffset.TryParse(isoTimestamp, out var ts)) return;

        UpdateCurrentValues(ts);

        // Update map cursor
        if (_leafletMap is not null && _positions is { Count: > 0 })
        {
            var nearest = FindNearestPosition(ts);
            if (nearest is not null)
            {
                await _leafletMap.UpdateCursorAsync(nearest.Latitude, nearest.Longitude);
            }
        }

        // Sync timeline slider
        if (_timelineSlicer is not null)
            await _timelineSlicer.SetTimestampAsync(ts);

        StateHasChanged();
    }

    private async Task OnMapTrackClicked(string isoTimestamp)
    {
        if (!DateTimeOffset.TryParse(isoTimestamp, out var ts)) return;

        UpdateCurrentValues(ts);

        // Sync charts to this timestamp
        if (_charts is not null)
        {
            await _charts.SyncCursorAsync(isoTimestamp);
        }

        // Sync timeline slider
        if (_timelineSlicer is not null)
            await _timelineSlicer.SetTimestampAsync(ts);

        StateHasChanged();
    }

    private async Task OnTimelineChanged(DateTimeOffset ts)
    {
        UpdateCurrentValues(ts);

        // Note: map cursor is already moved by JS (timelineInterop.onSliderInput)
        // so we only need to sync charts and gauges here.
        if (_charts is not null)
        {
            await _charts.SyncCursorAsync(ts.ToString("O"));
        }

        StateHasChanged();
    }

    private void UpdateCurrentValues(DateTimeOffset ts)
    {
        if (_positions is null || _positions.Count == 0) return;

        var pos = FindNearestPosition(ts);
        if (pos is null) return;

        _currentSog = pos.SpeedOverGround;
        _currentHeading = pos.CourseOverGround * (180.0 / Math.PI);
        _currentHeel = TelemetryMath.ComputeHeel(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
        _currentTrim = TelemetryMath.ComputeTrim(pos.QuaternionW, pos.QuaternionX, pos.QuaternionY, pos.QuaternionZ);
    }

    private PositionDto? FindNearestPosition(DateTimeOffset ts)
    {
        if (_positions is null || _positions.Count == 0) return null;
        return _positions.MinBy(p => Math.Abs((p.Time - ts).Ticks));
    }
}
