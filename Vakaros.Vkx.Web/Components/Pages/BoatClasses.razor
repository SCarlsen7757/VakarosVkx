@page "/boat-classes"
@using Vakaros.Vkx.Shared.Dtos.BoatClasses
@inject VakarosApiClient Api
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Boat Classes</PageTitle>

<h1>Boat Classes</h1>

@if (_loading)
{
    <p><em>Loading boat classes…</em></p>
}
else if (_error is not null)
{
    <div class="api-error" role="alert">
        <span class="api-error-icon">⚠️</span>
        <div class="api-error-body">
            <strong>Unable to load boat classes</strong>
            <p>@_error</p>
        </div>
    </div>
}
else
{
    <button class="btn btn-primary" @onclick="StartCreate" disabled="@(_editingId is not null)">+ New Boat Class</button>

    @if (_editing)
    {
        <div class="edit-form-panel">
            <h3>@(_editingId is null ? "Create Boat Class" : "Edit Boat Class")</h3>

            <div class="form-row">
                <label>Name</label>
                <input @bind="_formName" placeholder="Name" />
            </div>
            <div class="form-row">
                <label>LOA (m)</label>
                <input type="number" step="0.01" @bind="_formLoa" />
            </div>
            <div class="form-row">
                <label>Beam (m)</label>
                <input type="number" step="0.01" @bind="_formBeam" />
            </div>
            <div class="form-row">
                <label>Weight (kg)</label>
                <input type="number" step="0.1" @bind="_formWeight" />
            </div>
            <div class="form-row">
                <label>Bowsprit (m)</label>
                <input type="number" step="0.01" @bind="_formBowsprit" />
            </div>

            <h4>Sails</h4>
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Area (m²)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < _formSails.Count; i++)
                    {
                        var idx = i;
                        <tr>
                            <td><input @bind="_formSails[idx].Name" placeholder="Sail name" /></td>
                            <td><input type="number" step="0.01" @bind="_formSails[idx].Area" /></td>
                            <td><button class="btn btn-sm btn-danger" @onclick="() => _formSails.RemoveAt(idx)">Remove</button></td>
                        </tr>
                    }
                </tbody>
            </table>
            <button class="btn btn-sm" @onclick="AddSailRow">+ Add Sail</button>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveForm">Save</button>
                <button class="btn" @onclick="CancelEdit">Cancel</button>
            </div>
        </div>
    }

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>LOA (m)</th>
                <th>Beam (m)</th>
                <th>Weight (kg)</th>
                <th>Bowsprit (m)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (_boatClasses is not null)
            {
                @foreach (var bc in _boatClasses)
                {
                    <tr>
                        <td>@bc.Name</td>
                        <td>@(bc.LengthOverAll?.ToString("F2") ?? "—")</td>
                        <td>@(bc.Beam?.ToString("F2") ?? "—")</td>
                        <td>@(bc.Weight?.ToString("F1") ?? "—")</td>
                        <td>@(bc.BowspritLength?.ToString("F2") ?? "—")</td>
                        <td>
                            <button class="btn btn-sm" @onclick="() => StartEditAsync(bc)" disabled="@_editing">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(bc)" disabled="@_editing">Delete</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @if (_boatClasses is { Count: 0 } && !_editing)
    {
        <p>No boat classes found. Click <strong>+ New Boat Class</strong> to create one.</p>
    }

    @if (_actionError is not null)
    {
        <div class="api-error" role="alert">
            <span class="api-error-icon">⚠️</span>
            <div class="api-error-body">
                <p>@_actionError</p>
            </div>
        </div>
    }
}

@code {
    private List<BoatClassSummaryDto>? _boatClasses;
    private bool _loading = true;
    private string? _error;
    private string? _actionError;

    // Form state
    private bool _editing;
    private int? _editingId;
    private string _formName = "";
    private double? _formLoa;
    private double? _formBeam;
    private double? _formWeight;
    private double? _formBowsprit;
    private List<SailFormRow> _formSails = [];

    private class SailFormRow
    {
        public string Name { get; set; } = "";
        public double Area { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _boatClasses = await Api.GetBoatClassesAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Could not reach the API. Please check that the server is running and try again.";
        }
        catch (Exception ex)
        {
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartCreate()
    {
        _actionError = null;
        _editing = true;
        _editingId = null;
        _formName = "";
        _formLoa = null;
        _formBeam = null;
        _formWeight = null;
        _formBowsprit = null;
        _formSails = [];
    }

    private async Task StartEditAsync(BoatClassSummaryDto summary)
    {
        _actionError = null;
        try
        {
            var full = await Api.GetBoatClassAsync(summary.Id);
            if (full is null)
            {
                _actionError = "Could not load boat class details.";
                return;
            }

            _editing = true;
            _editingId = full.Id;
            _formName = full.Name;
            _formLoa = full.LengthOverAll;
            _formBeam = full.Beam;
            _formWeight = full.Weight;
            _formBowsprit = full.BowspritLength;
            _formSails = full.Sails.Select(s => new SailFormRow { Name = s.Name, Area = s.Area }).ToList();
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to load boat class: {ex.Message}";
        }
    }

    private void CancelEdit()
    {
        _editing = false;
        _editingId = null;
        _actionError = null;
    }

    private void AddSailRow()
    {
        _formSails.Add(new SailFormRow());
    }

    private async Task SaveForm()
    {
        _actionError = null;
        if (string.IsNullOrWhiteSpace(_formName))
        {
            _actionError = "Name is required.";
            return;
        }

        var sails = _formSails
            .Where(s => !string.IsNullOrWhiteSpace(s.Name))
            .Select(s => new SailRequest(s.Name.Trim(), s.Area))
            .ToList();

        try
        {
            if (_editingId is null)
            {
                var request = new CreateBoatClassRequest(_formName.Trim(), _formLoa, _formBeam, _formWeight, _formBowsprit, sails);
                await Api.CreateBoatClassAsync(request);
            }
            else
            {
                var request = new UpdateBoatClassRequest(_formName.Trim(), _formLoa, _formBeam, _formWeight, _formBowsprit, sails);
                await Api.UpdateBoatClassAsync(_editingId.Value, request);
            }

            // Reload the list
            _boatClasses = await Api.GetBoatClassesAsync();
            _editing = false;
            _editingId = null;
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to save boat class: {ex.Message}";
        }
    }

    private async Task Delete(BoatClassSummaryDto bc)
    {
        _actionError = null;
        try
        {
            await Api.DeleteBoatClassAsync(bc.Id);
            _boatClasses?.RemoveAll(x => x.Id == bc.Id);
        }
        catch (Exception ex)
        {
            _actionError = $"Failed to delete boat class: {ex.Message}";
        }
    }
}
